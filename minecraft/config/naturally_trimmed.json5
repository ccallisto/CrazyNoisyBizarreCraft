{
	// If enabled, the mod will try to apply trims to the equipment of mobs when they're newly spawning.
	enable_trim_mobs: true,
	// If enabled, the mod will try to apply trims to equipment generated by loot tables.
	// This includes chests or other containers, mob drops and more.
	enable_trim_loot_tables: true,
	// If enabled, the mod will try to apply trims to equipment of trades.
	// This includes villager trades like a diamond chestplate from armorer villagers, trades from wandering traders or modded trader mobs.
	enable_trim_trades: true,
	// Settings for determining/filtering which trims can be used by the mod
	trim_filtering: {
		// Enables filtering trims by checking for the corresponding textures of the trim.
		// However, this only works on the client, it will be not be applied on dedicated servers, due to textures not being available on dedicated servers.
		// 
		// See 'https://github.com/Imajo24I/Naturally-Trimmed/wiki/Config-%E2%80%90-3.5.0#texture-validation-filtering'
		// 
		// When this setting *is* applied (on client + enabled), it will override some built-in filtering (none of the other trim filtering config entries!).
		texture_validation_filtering: true,
		// Use only vanilla trim materials and patterns
		vanilla_only: false,
		// Filter trim materials.
		// 
		// See 'https://github.com/Imajo24I/Naturally-Trimmed/wiki/Config-‐-3.5.0#trim-material-filter--material_filter' for documentation on this.
		// 
		// Example configuration, blacklisting everything but biomes_o_plenty's trim materials and all trim materials that have the c:gold tag:
		// material_filter: ["+biomes_o_plenty:.*", "+#c:gold", "-.*"]
		material_filter: [],
		// Filter trim patterns.
		// 
		// See 'https://github.com/Imajo24I/Naturally-Trimmed/wiki/Config-‐-3.5.0#trim-pattern-filter--pattern_filter' for documentation on this.
		// 
		// Example configuration, blacklisting everything but the silence trim pattern
		// pattern_filter: ["+minecraft:silence", "-.*"]
		pattern_filter: [
			"-tooltrims:.*"
		]
	},
	// Settings for trimming a mob's equipment
	trim_mobs: {
		// Select the trim system. Trim systems define how the mod chooses what trims to use.
		// - RANDOM_TRIMS: Randomly chooses the trim to apply to the mob. Filtering from 'trim_filtering' applies to this.
		// - PREDEFINED_TRIMS: Chooses the trim from a list of predefined trims. See 'predefined_trims'. Filtering from 'trim_filtering' doesn't apply to this.
		trim_system: "RANDOM_TRIMS",
		// Chance of the mob having no trims at all
		no_trims_chance: 25,
		// Chance of each equipment piece having a trim applied. Applies individually to each armor piece.
		trim_chance: 75,
		// List of predefined trims.
		// 
		// See 'trim_system'.
		// A predefined trim consists of a trim material and a trim pattern.
		// The mod randomly selects a predefined trim to use out of this list.
		// 
		// Example configuration:
		// predefined_trims: [{material: "resin", pattern: "silence"}, {material: "netherite", pattern: "vex"}, {material: "minecraft:amethyst", pattern: "minecraft:silence"}]
		predefined_trims: []
	},
	// Settings for trimming equipment generated by loot tables
	trim_loot_tables: {
		// Chance of an item generated by a loot table having a trim applied
		trim_chance: 50
	},
	// Settings for trimming equipment from villager trades
	trim_trades: {
		// Chance of an item from a villager trade having a trim applied
		trim_chance: 50,
		// The minimum villager trading level an item needs to be in, to be considered of being trimmed
		min_level: 3
	}
}